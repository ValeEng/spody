# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# CMake build artifacts
build/
build-*/
out/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cbp
compile_commands.json

# Simulation outputs (results dirs created by `spody propagate --out`)
results/
*.csv
*.dat
*.bin
!examples/**/*.csv
!examples/**/*.dat

# Per-example output dirs: keep the directory shape (.gitkeep) but
# ignore anything spody propagate writes into them.
examples/**/output/*
!examples/**/output/.gitkeep

# GPS validation example: only the input.toml is tracked. The .sp3
# source files (gz + decompressed) and the converted reference binary
# are kept locally for fast re-runs, but redistributed via the URL in
# the TOML's source comment -- not committed.
examples/gps_g11_validation/*
!examples/gps_g11_validation/input.toml

# GLONASS validation example: only the input.toml is tracked. The
# .rnx broadcast nav source files and the converted reference binary
# are regenerable from the URL in the TOML's source comment.
examples/glonass_r03_validation/*
!examples/glonass_r03_validation/input.toml

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# PyInstaller bundle output (under python/). Built on demand by
# build_bundle.py; never committed -- the spec file is the only
# tracked artifact.
python/build/
python/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
note.txt

# Setup wizard data root (downloaded ephemeris + harmonics, plus the
# converted .spody binary). Sits at the repo root in dev mode so the
# GUI sees the same `data/` it would in a portable bundle.
data/

# Local-only diagnostic scripts (analogous to spody-core tvb/). These
# are ad-hoc tools used during development and not part of the shipped
# product.
tools/
