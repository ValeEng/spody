*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# CMake build artifacts
build/
build-*/
out/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cbp
compile_commands.json

# Simulation outputs (results dirs created by `spody propagate --out`)
results/
*.csv
*.dat
*.bin
!examples/**/*.csv
!examples/**/*.dat

# Per-example output dirs: keep the directory shape (.gitkeep) but
# ignore anything spody propagate writes into them.
examples/**/output/*
!examples/**/output/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# PyInstaller bundle output (under python/). Built on demand by
# build_bundle.py; never committed -- the spec file is the only
# tracked artifact.
python/build/
python/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
note.txt

# Setup wizard data root (downloaded ephemeris + harmonics, plus the
# converted .spody binary). Sits at the repo root in dev mode so the
# GUI sees the same `data/` it would in a portable bundle.
data/
